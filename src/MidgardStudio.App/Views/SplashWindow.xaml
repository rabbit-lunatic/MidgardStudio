<Window x:Class="MidgardStudio.App.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True"
        WindowStartupLocation="CenterScreen"
        Width="500" Height="360">

    <!-- Branded, animated splash. Self-contained (it runs on its own UI thread while the main thread loads
         the workspace) so it defines all of its own brushes/animations and shares nothing with App resources. -->
    <Border x:Name="Card" Margin="30" CornerRadius="18" BorderThickness="1" BorderBrush="#3FA15CF5"
            Opacity="0" RenderTransformOrigin="0.5,0.5" ClipToBounds="True">
        <Border.Background>
            <RadialGradientBrush GradientOrigin="0.5,0.28" Center="0.5,0.32" RadiusX="0.95" RadiusY="1.1">
                <GradientStop Color="#26193F" Offset="0.0" />
                <GradientStop Color="#140F24" Offset="0.55" />
                <GradientStop Color="#0A0712" Offset="1.0" />
            </RadialGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#8D2DF2" BlurRadius="48" ShadowDepth="0" Opacity="0.45" />
        </Border.Effect>
        <Border.RenderTransform>
            <ScaleTransform x:Name="CardScale" ScaleX="0.92" ScaleY="0.92" />
        </Border.RenderTransform>

        <Grid>
            <!-- Soft pulsing glow behind the logo -->
            <Ellipse x:Name="Glow" Width="300" Height="300" VerticalAlignment="Center" HorizontalAlignment="Center"
                     Margin="0,-66,0,0" Opacity="0.5" RenderTransformOrigin="0.5,0.5" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#5C9A3DF5" Offset="0.0" />
                        <GradientStop Color="#00120A20" Offset="0.7" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <ScaleTransform x:Name="GlowScale" ScaleX="0.9" ScaleY="0.9" />
                </Ellipse.RenderTransform>
            </Ellipse>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image x:Name="Logo" Source="/Assets/logo.png" Width="94" Height="94" HorizontalAlignment="Center"
                       RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="LogoScale" ScaleX="0.5" ScaleY="0.5" />
                            <TranslateTransform x:Name="LogoFloat" Y="0" />
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>

                <TextBlock x:Name="TitleText" Text="Midgard Studio" FontSize="32" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,16,0,0" Foreground="#E8E2F4" />
                <TextBlock Text="S E R V E R   ·   C L I E N T   ·   O N E   S T U D I O" FontSize="9.5"
                           HorizontalAlignment="Center" Margin="0,7,0,0" Foreground="#8A82A8" />

                <!-- Indeterminate shimmer progress -->
                <Border Width="240" Height="4" CornerRadius="2" Background="#1AFFFFFF" Margin="0,28,0,0" ClipToBounds="True">
                    <Border x:Name="Shimmer" Width="90" Height="4" CornerRadius="2" HorizontalAlignment="Left">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#008D2DF2" Offset="0.0" />
                                <GradientStop Color="#D916FB" Offset="0.5" />
                                <GradientStop Color="#008D2DF2" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="ShimmerMove" X="-90" />
                        </Border.RenderTransform>
                    </Border>
                </Border>
                <TextBlock Text="Loading your workspace…" FontSize="11" HorizontalAlignment="Center"
                           Margin="0,13,0,0" Foreground="#6E6788" />
            </StackPanel>
        </Grid>

        <Border.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <!-- Card entrance: fade + spring up -->
                        <DoubleAnimation Storyboard.TargetName="Card" Storyboard.TargetProperty="Opacity"
                                         To="1" Duration="0:0:0.28" />
                        <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX"
                                         To="1" Duration="0:0:0.45">
                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5" /></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY"
                                         To="1" Duration="0:0:0.45">
                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5" /></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>

                        <!-- Logo pops in slightly after the card -->
                        <DoubleAnimation Storyboard.TargetName="LogoScale" Storyboard.TargetProperty="ScaleX"
                                         To="1" BeginTime="0:0:0.14" Duration="0:0:0.5">
                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.6" /></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="LogoScale" Storyboard.TargetProperty="ScaleY"
                                         To="1" BeginTime="0:0:0.14" Duration="0:0:0.5">
                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.6" /></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>

                        <!-- Glow breathes forever -->
                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity"
                                         From="0.35" To="0.72" Duration="0:0:1.7" AutoReverse="True" RepeatBehavior="Forever" />
                        <DoubleAnimation Storyboard.TargetName="GlowScale" Storyboard.TargetProperty="ScaleX"
                                         From="0.9" To="1.08" Duration="0:0:1.7" AutoReverse="True" RepeatBehavior="Forever" />
                        <DoubleAnimation Storyboard.TargetName="GlowScale" Storyboard.TargetProperty="ScaleY"
                                         From="0.9" To="1.08" Duration="0:0:1.7" AutoReverse="True" RepeatBehavior="Forever" />

                        <!-- Logo gently floats after it lands -->
                        <DoubleAnimation Storyboard.TargetName="LogoFloat" Storyboard.TargetProperty="Y"
                                         From="0" To="-5" BeginTime="0:0:0.65" Duration="0:0:1.9" AutoReverse="True" RepeatBehavior="Forever" />

                        <!-- Indeterminate progress shimmer -->
                        <DoubleAnimation Storyboard.TargetName="ShimmerMove" Storyboard.TargetProperty="X"
                                         From="-90" To="240" Duration="0:0:1.25" RepeatBehavior="Forever" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
    </Border>
</Window>
