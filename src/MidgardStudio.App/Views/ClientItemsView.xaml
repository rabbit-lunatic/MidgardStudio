<UserControl x:Class="MidgardStudio.App.Views.ClientItemsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:MidgardStudio.App.ViewModels"
             xmlns:common="clr-namespace:MidgardStudio.App.Common"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ClientItemsViewModel}">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48" />
            <TextBlock Text="Loading client items…" Opacity="0.7" Margin="0,12,0,0" HorizontalAlignment="Center" />
        </StackPanel>

        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" MinWidth="300" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="420" />
            </Grid.ColumnDefinitions>

            <!-- Master list -->
            <DockPanel Grid.Column="0" Margin="0,0,8,0">
                <ui:TextBox DockPanel.Dock="Top" Margin="0,0,0,8" PlaceholderText="Search id / aegis / name…"
                            Text="{Binding List.SearchText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                <TextBlock DockPanel.Dock="Bottom" Text="{Binding List.StatusText}" Opacity="0.6"
                           Margin="2,6,0,0" FontSize="11" />
                <ListView x:Name="MasterList" ItemsSource="{Binding List.Rows}"
                          SelectedItem="{Binding List.SelectedRow, Mode=TwoWay}"
                          SelectionMode="Extended"
                          common:ListBehaviors.SelectedItems="{Binding List.SelectedRows}"
                          Background="Transparent" BorderThickness="0"
                          ItemContainerStyle="{StaticResource MasterListItem}"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          VirtualizingPanel.ScrollUnit="Pixel"
                          ScrollViewer.VerticalScrollBarVisibility="Visible"
                          ScrollViewer.IsDeferredScrollingEnabled="False"
                          common:ListBehaviors.SelectOnRightClick="True">
                    <ListView.InputBindings>
                        <KeyBinding Key="A" Modifiers="Control+Shift" Command="{Binding AutocompleteSelectedCommand}" />
                        <KeyBinding Key="C" Modifiers="Control" Command="{Binding CopyClientLuaCommand}" />
                    </ListView.InputBindings>
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Autocomplete from server" InputGestureText="Ctrl+Shift+A"
                                      Command="{Binding PlacementTarget.DataContext.AutocompleteSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      ToolTip="Generate the identified name + description (type-aware, from server stats + script) plus slots / ClassNum. Select several (Ctrl/Shift+click) to run it in bulk.">
                                <MenuItem.Icon><ui:SymbolIcon Symbol="Sparkle24" /></MenuItem.Icon>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="Copy client Lua" InputGestureText="Ctrl+C"
                                      Command="{Binding PlacementTarget.DataContext.CopyClientLuaCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      ToolTip="Copy this item's itemInfo Lua block to the clipboard">
                                <MenuItem.Icon><ui:SymbolIcon Symbol="ClipboardLink24" /></MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </ListView.ContextMenu>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="" Width="70">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="3" Padding="5,1" HorizontalAlignment="Left"
                                                Background="{Binding Origin, Converter={StaticResource OriginBrush}}">
                                            <TextBlock Text="{Binding Origin, Converter={StaticResource OriginLabel}}"
                                                       FontSize="9.5" FontWeight="SemiBold" Foreground="White" />
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="" Width="30">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding Icon}" Width="22" Height="22"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn x:Name="IdColumn" Header="ID" Width="60" DisplayMemberBinding="{Binding KeyText}" />
                            <GridViewColumn x:Name="NameColumn" Header="Name" Width="166" DisplayMemberBinding="{Binding Name}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="#22FFFFFF" />

            <!-- Detail -->
            <Grid Grid.Column="2" Margin="8,0,0,0">
                <TextBlock Text="Select an item to edit its client info." Opacity="0.5"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding HasEditor, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0"
                              Visibility="{Binding HasEditor, Converter={StaticResource BoolToVis}}">
                    <StackPanel DataContext="{Binding Editor}" TextElement.FontSize="12">

                        <!-- Header: target label + autocomplete / copy actions -->
                        <DockPanel Margin="0,0,0,10">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <ui:Button Content="Autocomplete" Appearance="Secondary" Padding="10,4"
                                           Command="{Binding AutocompleteCommand}"
                                           ToolTip="Generate the identified name + description (type-aware, from the server item's stats and script) plus slots / ClassNum (Ctrl+Shift+A)">
                                    <ui:Button.Icon><ui:SymbolIcon Symbol="Sparkle24" /></ui:Button.Icon>
                                </ui:Button>
                                <ui:Button Content="Copy Lua" Appearance="Transparent" Padding="10,4" Margin="6,0,0,0"
                                           Command="{Binding CopyLuaCommand}"
                                           ToolTip="Copy this item's itemInfo Lua block to the clipboard (Ctrl+C)">
                                    <ui:Button.Icon><ui:SymbolIcon Symbol="ClipboardLink24" /></ui:Button.Icon>
                                </ui:Button>
                            </StackPanel>
                            <TextBlock Text="{Binding TargetLabel}" Opacity="0.7" FontSize="11.5" VerticalAlignment="Center" />
                        </DockPanel>

                        <!-- Description toolbar (acts on the focused description box) -->
                        <ui:Card Padding="10,8" Margin="0,0,0,10">
                            <DockPanel>
                                <TextBlock Text="Color" Opacity="0.7" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <ui:Button x:Name="NewLineButton" Content="↵ New line" Focusable="False" Margin="8,0,0,0"
                                               ToolTip="Insert a blank line (^FFFFFF_^000000)" />
                                    <ui:Button x:Name="ResetColorButton" Content="Reset ^000000" Focusable="False" Margin="6,0,0,0"
                                               ToolTip="Reset text color to black" />
                                </StackPanel>
                                <WrapPanel x:Name="SwatchPanel">
                                    <Border Width="20" Height="20" Margin="2" CornerRadius="3" BorderThickness="1" BorderBrush="#55000000" Background="#000000" Tag="000000" Cursor="Hand" MouseLeftButtonDown="Swatch_Click" />
                                    <Border Width="20" Height="20" Margin="2" CornerRadius="3" BorderThickness="1" BorderBrush="#55000000" Background="#FFFFFF" Tag="FFFFFF" Cursor="Hand" MouseLeftButtonDown="Swatch_Click" />
                                    <Border Width="20" Height="20" Margin="2" CornerRadius="3" BorderThickness="1" BorderBrush="#55000000" Background="#FF0000" Tag="FF0000" Cursor="Hand" MouseLeftButtonDown="Swatch_Click" />
                                    <Border Width="20" Height="20" Margin="2" CornerRadius="3" BorderThickness="1" BorderBrush="#55000000" Background="#009900" Tag="009900" Cursor="Hand" MouseLeftButtonDown="Swatch_Click" />
                                    <Border Width="20" Height="20" Margin="2" CornerRadius="3" BorderThickness="1" BorderBrush="#55000000" Background="#0000FF" Tag="0000FF" Cursor="Hand" MouseLeftButtonDown="Swatch_Click" />
                                    <Border Width="20" Height="20" Margin="2" CornerRadius="3" BorderThickness="1" BorderBrush="#55000000" Background="#EFA300" Tag="EFA300" Cursor="Hand" MouseLeftButtonDown="Swatch_Click" />
                                    <Border Width="20" Height="20" Margin="2" CornerRadius="3" BorderThickness="1" BorderBrush="#55000000" Background="#A335EE" Tag="A335EE" Cursor="Hand" MouseLeftButtonDown="Swatch_Click" />
                                    <Border Width="20" Height="20" Margin="2" CornerRadius="3" BorderThickness="1" BorderBrush="#55000000" Background="#00AEEF" Tag="00AEEF" Cursor="Hand" MouseLeftButtonDown="Swatch_Click" />
                                    <Border Width="20" Height="20" Margin="2" CornerRadius="3" BorderThickness="1" BorderBrush="#55000000" Background="#777777" Tag="777777" Cursor="Hand" MouseLeftButtonDown="Swatch_Click" />
                                </WrapPanel>
                            </DockPanel>
                        </ui:Card>

                        <!-- Identified / Unidentified sections -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="48" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Copy between the two cards -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ui:Button Content="→" MinWidth="0" Padding="8,4" Margin="0,0,0,8" FontSize="15"
                                           Command="{Binding CopyToUnidentifiedCommand}"
                                           ToolTip="Copy identified name + description → unidentified" />
                                <ui:Button Content="←" MinWidth="0" Padding="8,4" FontSize="15"
                                           Command="{Binding CopyToIdentifiedCommand}"
                                           ToolTip="Copy unidentified name + description → identified" />
                            </StackPanel>

                            <!-- Identified -->
                            <ui:Card Grid.Column="0" Padding="12,10">
                                <StackPanel>
                                    <TextBlock Text="Identified" Style="{StaticResource SectionTitle}" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <TextBlock Text="Display name" Opacity="0.8" Margin="0,0,0,2" />
                                    <ui:TextBox Text="{Binding IdentifiedDisplayName, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" />
                                    <TextBlock Text="Resource name" Opacity="0.8" Margin="0,0,0,2" />
                                    <ui:TextBox Text="{Binding IdentifiedResourceName, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" />
                                    <TextBlock Text="Description" Opacity="0.8" Margin="0,0,0,2" />
                                    <ui:TextBox x:Name="IdDescBox" Text="{Binding IdentifiedDescription, UpdateSourceTrigger=LostFocus}"
                                                AcceptsReturn="True" MinHeight="120" MaxHeight="220" FontFamily="Consolas"
                                                VerticalScrollBarVisibility="Auto" TextChanged="IdDesc_TextChanged"
                                                GotKeyboardFocus="DescBox_GotFocus" />

                                    <TextBlock Text="Preview" Opacity="0.55" FontSize="11" Margin="0,10,0,3" />
                                    <Border Background="#EFEAD9" CornerRadius="4" Padding="8" MinHeight="70">
                                        <DockPanel>
                                            <Image DockPanel.Dock="Left" Source="{Binding IconPreview}" Width="40" Height="40"
                                                   Margin="0,0,8,0" VerticalAlignment="Top" RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                            <StackPanel>
                                                <TextBlock Text="{Binding IdentifiedDisplayName}" FontWeight="Bold" Foreground="Black" TextWrapping="Wrap" />
                                                <TextBlock x:Name="IdPreview" Foreground="Black" TextWrapping="Wrap" FontSize="11.5" Margin="0,2,0,0" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </StackPanel>
                            </ui:Card>

                            <!-- Unidentified -->
                            <ui:Card Grid.Column="2" Padding="12,10">
                                <StackPanel>
                                    <TextBlock Text="Unidentified" Style="{StaticResource SectionTitle}" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <TextBlock Text="Display name" Opacity="0.8" Margin="0,0,0,2" />
                                    <ui:TextBox Text="{Binding UnidentifiedDisplayName, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" />
                                    <TextBlock Text="Resource name" Opacity="0.8" Margin="0,0,0,2" />
                                    <ui:TextBox Text="{Binding UnidentifiedResourceName, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" />
                                    <TextBlock Text="Description" Opacity="0.8" Margin="0,0,0,2" />
                                    <ui:TextBox x:Name="UnidDescBox" Text="{Binding UnidentifiedDescription, UpdateSourceTrigger=LostFocus}"
                                                AcceptsReturn="True" MinHeight="120" MaxHeight="220" FontFamily="Consolas"
                                                VerticalScrollBarVisibility="Auto" TextChanged="UnidDesc_TextChanged"
                                                GotKeyboardFocus="DescBox_GotFocus" />

                                    <TextBlock Text="Preview" Opacity="0.55" FontSize="11" Margin="0,10,0,3" />
                                    <Border Background="#EFEAD9" CornerRadius="4" Padding="8" MinHeight="70">
                                        <DockPanel>
                                            <Image DockPanel.Dock="Left" Source="{Binding IconPreview}" Width="40" Height="40"
                                                   Margin="0,0,8,0" VerticalAlignment="Top" RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                            <StackPanel>
                                                <TextBlock Text="{Binding UnidentifiedDisplayName}" FontWeight="Bold" Foreground="Black" TextWrapping="Wrap" />
                                                <TextBlock x:Name="UnidPreview" Foreground="Black" TextWrapping="Wrap" FontSize="11.5" Margin="0,2,0,0" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </StackPanel>
                            </ui:Card>
                        </Grid>

                        <!-- Common client fields -->
                        <ui:Card Padding="12,10" Margin="0,10,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Slots" VerticalAlignment="Center" Opacity="0.85" Width="60" />
                                    <ui:TextBox Text="{Binding SlotCount, UpdateSourceTrigger=LostFocus}" Width="60" Margin="0,0,16,0" />
                                    <TextBlock Text="ClassNum / View" VerticalAlignment="Center" Opacity="0.85" Width="110" />
                                    <ui:TextBox Text="{Binding ClassNum, UpdateSourceTrigger=LostFocus}" Width="70" Margin="0,0,16,0" />
                                    <ui:ToggleSwitch Content="Costume" IsChecked="{Binding Costume}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                            Visibility="{Binding CanLinkSprite, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Headgear sprite" VerticalAlignment="Center" Opacity="0.85" Width="100" />
                                    <ui:TextBox Text="{Binding SpriteName, UpdateSourceTrigger=PropertyChanged}"
                                                PlaceholderText="sprite base name" Width="180" Margin="0,0,8,0" />
                                    <ui:Button Content="Link sprite" Command="{Binding LinkSpriteCommand}" />
                                </StackPanel>
                                <TextBlock Text="{Binding SpriteLinkMessage}" Opacity="0.8" Foreground="#7FD0A0" TextWrapping="Wrap"
                                           Visibility="{Binding SpriteLinkMessage, Converter={StaticResource StringToVis}}" Margin="0,4,0,0" />
                            </StackPanel>
                        </ui:Card>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
