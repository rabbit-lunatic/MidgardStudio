<UserControl x:Class="MidgardStudio.App.Views.ConfigurationWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:MidgardStudio.App.ViewModels"
             mc:Ignorable="d"
             PreviewKeyDown="OnPreviewKeyDown"
             d:DataContext="{d:DesignInstance Type=vm:ConfigurationWizardViewModel}">

    <UserControl.Resources>
        <!-- Profile list row: rounded, highlights on hover + selection (mirrors the Settings nav). The
             content is stretched so the delete button always sits flush at the right edge. -->
        <Style x:Key="ProfileListItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="#D8D8E4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" CornerRadius="7" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#14FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E8D2DF2" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- One path field: caption + (text box, with a Browse button docked right). -->
        <Style x:Key="FieldCaption" TargetType="TextBlock">
            <Setter Property="Opacity" Value="0.8" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,20,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Header: title + subtitle, with a Close (exit) button at the top-right ===== -->
        <Grid Grid.Row="0" Margin="0,0,0,18">
            <StackPanel VerticalAlignment="Center" Margin="0,0,44,0">
                <TextBlock Text="Workspace configuration" Style="{StaticResource TitleScreen}" />
                <TextBlock Opacity="0.65" FontSize="12.5" Margin="0,4,0,0" TextWrapping="Wrap"
                           Text="Manage the servers you edit. Pick a profile on the left, set its files on the right, then Open." />
            </StackPanel>
            <ui:Button HorizontalAlignment="Right" VerticalAlignment="Top" Appearance="Transparent" Padding="8"
                       Command="{Binding CloseCommand}" ToolTip="Close configuration (Esc)">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Dismiss24" FontSize="18" /></ui:Button.Icon>
            </ui:Button>
        </Grid>

        <!-- ===== Body: profiles list (left) + editor (right) ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Profiles -->
            <DockPanel Grid.Column="0" Margin="0,0,20,0">
                <TextBlock DockPanel.Dock="Top" Text="Profiles" Style="{StaticResource TitleSection}" Margin="2,0,0,8" />
                <ui:Button DockPanel.Dock="Bottom" Content="New profile" Command="{Binding NewProfileCommand}"
                           Appearance="Secondary" HorizontalAlignment="Stretch" Margin="0,10,0,0">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Add24" /></ui:Button.Icon>
                </ui:Button>
                <Border BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="8" Background="#16000000" Padding="4">
                    <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ItemContainerStyle="{StaticResource ProfileListItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <!-- Hover reveals the full set of paths for this profile -->
                                <Grid>
                                    <Grid.ToolTip>
                                        <ToolTip MaxWidth="560">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" />
                                                <TextBlock Text="{Binding DefaultMode}" Opacity="0.6" FontSize="11" Margin="0,0,0,4" />
                                                <Border Height="1" Background="#22FFFFFF" Margin="0,2,0,6" />
                                                <TextBlock Text="Server DB" Opacity="0.5" FontSize="10.5" />
                                                <TextBlock Text="{Binding Paths.ServerDbRoot}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" />
                                                <TextBlock Text="Client lua-files" Opacity="0.5" FontSize="10.5" Margin="0,5,0,0" />
                                                <TextBlock Text="{Binding Paths.LuaFilesRoot}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" />
                                                <TextBlock Text="Base item info" Opacity="0.5" FontSize="10.5" Margin="0,5,0,0" />
                                                <TextBlock Text="{Binding Paths.ItemInfoPath}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" />
                                                <TextBlock Text="Custom item info" Opacity="0.5" FontSize="10.5" Margin="0,5,0,0" />
                                                <TextBlock Text="{Binding Paths.ItemInfoCustomPath}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding GrfPaths.Count, StringFormat='{}{0} GRF / data path(s)'}"
                                                           Opacity="0.7" FontSize="11" Margin="0,7,0,0" />
                                            </StackPanel>
                                        </ToolTip>
                                    </Grid.ToolTip>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <Border Background="#33FFFFFF" CornerRadius="3" Padding="5,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DefaultMode}" FontSize="10" Opacity="0.9" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Paths.ServerDbRoot}" Opacity="0.5" FontSize="10.5"
                                                   FontFamily="Consolas" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <ui:Button Grid.Column="1" Appearance="Transparent" VerticalAlignment="Center" Padding="6"
                                               ToolTip="Delete this profile"
                                               Command="{Binding DataContext.DeleteProfileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                               CommandParameter="{Binding}">
                                        <ui:Button.Icon><ui:SymbolIcon Symbol="Delete24" FontSize="16" /></ui:Button.Icon>
                                    </ui:Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>

            <!-- Editor -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                <StackPanel MaxWidth="720" HorizontalAlignment="Left">

                    <!-- Profile basics — name + ruleset share a row, encoding + its help share the next, to keep
                         the card short. -->
                    <ui:Card Padding="16,14">
                        <StackPanel>
                            <TextBlock Text="Profile" Style="{StaticResource SectionTitle}" Margin="0,0,0,10" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Profile name" Style="{StaticResource FieldCaption}" />
                                    <ui:TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                    <TextBlock Text="System (ruleset)" Style="{StaticResource FieldCaption}" />
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton Content="Renewal" GroupName="System" VerticalAlignment="Center"
                                                     IsChecked="{Binding IsRenewal}" Margin="0,0,20,0" />
                                        <RadioButton Content="Pre-Renewal" GroupName="System" VerticalAlignment="Center"
                                                     IsChecked="{Binding IsRenewal, Converter={StaticResource InverseBool}}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Display Encoding" Style="{StaticResource FieldCaption}" />
                                    <ComboBox ItemsSource="{Binding EncodingOptions}"
                                              SelectedValuePath="Codepage" DisplayMemberPath="Label"
                                              SelectedValue="{Binding SelectedCodepage}"
                                              Width="300" HorizontalAlignment="Left" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Opacity="0.55" FontSize="11" TextWrapping="Wrap"
                                           Text="Fallback used to read legacy, non-UTF-8 names in your server database files (e.g. a Latin-1 “Poção” or an EUC-KR item_db). Server files are saved as UTF-8; client text and icon / sprite resource names always use the standard Windows-1252." />
                            </Grid>
                        </StackPanel>
                    </ui:Card>

                    <!-- Server & client files -->
                    <ui:Card Padding="16,14" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Server &amp; client files" Style="{StaticResource SectionTitle}" Margin="0,0,0,4" />
                            <TextBlock Opacity="0.6" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"
                                       Text="Point the app at this server's files. The GRF archives below are what the GRF Browser reads — you don't set them again there." />

                            <TextBlock Text="Server DB Folder  ( ../rAthena/db )" Style="{StaticResource FieldCaption}" />
                            <DockPanel>
                                <ui:Button DockPanel.Dock="Right" Content="Browse…" Command="{Binding BrowseServerDbCommand}" Margin="8,0,0,0" />
                                <ui:TextBox Text="{Binding ServerDbRoot, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>

                            <TextBlock Text="Client Lua files  ( data/luafiles514/lua files )" Style="{StaticResource FieldCaption}" Margin="0,12,0,3" />
                            <DockPanel>
                                <ui:Button DockPanel.Dock="Right" Content="Browse…" Command="{Binding BrowseLuaFilesCommand}" Margin="8,0,0,0" />
                                <ui:TextBox Text="{Binding LuaFilesRoot, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>

                            <TextBlock Text="Base iteminfo.lua  ( SystemEN/LuaFiles514/itemInfo.lua )"
                                       Style="{StaticResource FieldCaption}" Margin="0,12,0,3" />
                            <DockPanel>
                                <ui:Button DockPanel.Dock="Right" Content="Browse…" Command="{Binding BrowseItemInfoCommand}" Margin="8,0,0,0" />
                                <ui:TextBox Text="{Binding ItemInfoPath, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="…\System\itemInfo.lua (optional)" />
                            </DockPanel>

                            <TextBlock Text="Custom Iteminfo.lua  ( SystemEN/itemInfo_C.lua )"
                                       Style="{StaticResource FieldCaption}" Margin="0,12,0,3" />
                            <DockPanel>
                                <ui:Button DockPanel.Dock="Right" Content="Browse…" Command="{Binding BrowseItemInfoCustomCommand}" Margin="8,0,0,0" />
                                <ui:TextBox Text="{Binding ItemInfoCustomPath, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="…\System\itemInfo_C.lua (leave empty to write into the base file)" />
                            </DockPanel>
                        </StackPanel>
                    </ui:Card>

                    <!-- GRF archives & data folders -->
                    <ui:Card Padding="16,14" Margin="0,12,0,0">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="GRF archives &amp; data folders" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <ui:Button Content="Add GRF…" Command="{Binding AddGrfCommand}" Margin="0,0,6,0">
                                        <ui:Button.Icon><ui:SymbolIcon Symbol="FolderZip24" /></ui:Button.Icon>
                                    </ui:Button>
                                    <ui:Button Content="Add data folder…" Command="{Binding AddDataFolderCommand}" />
                                </StackPanel>
                            </DockPanel>
                            <Border BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="6" MinHeight="56" Padding="2">
                                <ListBox x:Name="GrfList" ItemsSource="{Binding GrfPaths}" Background="Transparent" BorderThickness="0"
                                         AllowDrop="True" AlternationCount="2000"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         PreviewMouseLeftButtonDown="GrfList_PreviewMouseLeftButtonDown"
                                         PreviewMouseMove="GrfList_PreviewMouseMove"
                                         DragOver="GrfList_DragOver" Drop="GrfList_Drop">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="4,3" />
                                            <Setter Property="Margin" Value="0,1" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Background="Transparent">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ui:SymbolIcon Grid.Column="0" Symbol="ReOrderDotsVertical24" FontSize="16" Opacity="0.4"
                                                               VerticalAlignment="Center" Margin="2,0,8,0" ToolTip="Drag to reorder priority" />
                                                <Border Grid.Column="1" Background="#338D2DF2" CornerRadius="9" MinWidth="20" Height="18"
                                                        VerticalAlignment="Center" Margin="0,0,9,0" ToolTip="Layer priority (the bottom entry wins)">
                                                    <TextBlock Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ListBoxItem}, Converter={StaticResource PlusOne}}"
                                                               FontSize="10.5" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.9" Padding="5,0" />
                                                </Border>
                                                <TextBlock Grid.Column="2" Text="{Binding}" VerticalAlignment="Center" FontFamily="Consolas" FontSize="11"
                                                           ToolTip="{Binding}" TextTrimming="CharacterEllipsis" />
                                                <ui:Button Grid.Column="3" Appearance="Transparent" ToolTip="Remove" Padding="6"
                                                           Command="{Binding DataContext.RemoveGrfCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                           CommandParameter="{Binding}">
                                                    <ui:Button.Icon><ui:SymbolIcon Symbol="Dismiss24" FontSize="14" /></ui:Button.Icon>
                                                </ui:Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                            <TextBlock Opacity="0.5" FontSize="11" Margin="2,6,0,0" TextWrapping="Wrap"
                                       Text="Drag the handle to reorder. Layers load top → bottom — an entry overrides everything above it (the bottom wins). Optional — leave empty to skip GRF previews." />
                        </StackPanel>
                    </ui:Card>

                    <!-- Status + actions -->
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#7FD0A0" TextWrapping="Wrap" Margin="2,14,0,0"
                               Visibility="{Binding StatusMessage, Converter={StaticResource StringToVis}}" />

                    <StackPanel Orientation="Horizontal" Margin="0,16,0,4">
                        <ui:Button Content="Save profile" Command="{Binding SaveProfileCommand}" Margin="0,0,10,0">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="Save24" /></ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Content="Open" Appearance="Primary" Command="{Binding OpenCommand}" Margin="0,0,10,0">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="Open24" /></ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Content="Close" Command="{Binding CloseCommand}">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="Dismiss24" /></ui:Button.Icon>
                        </ui:Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
