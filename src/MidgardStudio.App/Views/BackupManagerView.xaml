<UserControl x:Class="MidgardStudio.App.Views.BackupManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:MidgardStudio.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:BackupManagerViewModel}">

    <DockPanel>
        <!-- Toolbar -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Backup Manager" Style="{StaticResource TitleScreen}" />
                <TextBlock Opacity="0.65" FontSize="12" TextWrapping="Wrap"
                           Text="A snapshot of your server + client data is taken after each manual save; unchanged files are de-duplicated to save space. Restore, pin, verify, or export any point in time below." />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <ui:Button Content="Create backup now" Appearance="Primary" Command="{Binding CreateNowCommand}" Margin="0,0,8,0">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Save24" /></ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="Import…" Command="{Binding ImportCommand}" Margin="0,0,8,0" />
                <ui:Button Content="Open folder" Command="{Binding OpenFolderCommand}" Margin="0,0,8,0">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Folder24" /></ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="Refresh" Command="{Binding RefreshCommand}" />
            </StackPanel>
        </Grid>

        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Foreground="#7FD0A0"
                   TextWrapping="Wrap" Margin="2,10,0,0"
                   Visibility="{Binding StatusMessage, Converter={StaticResource StringToVis}}" />

        <!-- Empty state -->
        <Border Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="420">
                <ui:SymbolIcon Symbol="Folder24" FontSize="52" HorizontalAlignment="Center" Opacity="0.4" />
                <TextBlock Text="No backups yet" FontSize="18" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,12,0,4" />
                <TextBlock TextAlignment="Center" Opacity="0.65" TextWrapping="Wrap"
                           Text="Backups are created automatically each time you save. You can also create one now with the button above." />
            </StackPanel>
        </Border>

        <!-- Backups: list + details -->
        <Grid Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="320" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="3*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="6" Background="#0AFFFFFF">
                <ListView ItemsSource="{Binding Items}" SelectedItem="{Binding Selected, Mode=TwoWay}"
                          Background="Transparent" BorderThickness="0"
                          ItemContainerStyle="{StaticResource MasterListItem}"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="" Width="26">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ui:SymbolIcon Symbol="Pin28" FontSize="14" Foreground="#9A5FF4" ToolTip="Pinned — kept regardless of retention"
                                                       Visibility="{Binding Pinned, Converter={StaticResource BoolToVis}}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="When" Width="120" DisplayMemberBinding="{Binding RelativeText}" />
                            <GridViewColumn Header="Label" Width="170" DisplayMemberBinding="{Binding Label}" />
                            <GridViewColumn Header="Files" Width="50" DisplayMemberBinding="{Binding FileCount}" />
                            <GridViewColumn Header="Size" Width="74" DisplayMemberBinding="{Binding SizeText}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <!-- Details -->
            <ui:Card Grid.Column="2" Padding="16,14" Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                <DockPanel DataContext="{Binding Selected}">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="{Binding Label}" FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding DayText}" Opacity="0.7" Margin="0,2,0,0" />
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Border Background="#1FFFFFFF" CornerRadius="3" Padding="8,3" Margin="0,0,8,0">
                                <TextBlock Text="{Binding WhenText}" FontSize="11.5" />
                            </Border>
                            <Border Background="#1FFFFFFF" CornerRadius="3" Padding="8,3" Margin="0,0,8,0">
                                <TextBlock FontSize="11.5">
                                    <Run Text="{Binding FileCount, Mode=OneWay}" /><Run Text=" files" />
                                </TextBlock>
                            </Border>
                            <Border Background="#1FFFFFFF" CornerRadius="3" Padding="8,3" Margin="0,0,8,0">
                                <TextBlock Text="{Binding SizeText}" FontSize="11.5" />
                            </Border>
                            <Border Background="#1F7F6FD4" CornerRadius="3" Padding="8,3">
                                <TextBlock FontSize="11.5"
                                           Text="{Binding DataContext.EncodingChip, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding Note}" Opacity="0.7" TextWrapping="Wrap" Margin="0,10,0,0"
                                   Visibility="{Binding Note, Converter={StaticResource StringToVis}}" />
                        <TextBlock Text="Files in this backup" Opacity="0.55" FontSize="11" Margin="0,14,0,4" />
                    </StackPanel>

                    <!-- Actions pinned to the bottom -->
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,12,0,0">
                        <ui:Button Content="Restore this backup" Appearance="Primary" Margin="0,0,8,0"
                                   Command="{Binding DataContext.RestoreCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   CommandParameter="{Binding}">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowUndo24" /></ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Content="{Binding DataContext.PinButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}" Margin="0,0,8,0"
                                   Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   CommandParameter="{Binding}" />
                        <ui:Button Content="Verify" Margin="0,0,8,0"
                                   Command="{Binding DataContext.VerifyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   CommandParameter="{Binding}" />
                        <ui:Button Content="Export…" Margin="0,0,8,0"
                                   Command="{Binding DataContext.ExportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   CommandParameter="{Binding}" />
                        <ui:Button Content="Open" Margin="0,0,8,0"
                                   Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   CommandParameter="{Binding}">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="Folder24" /></ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Content="Delete"
                                   Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   CommandParameter="{Binding}">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="Delete24" /></ui:Button.Icon>
                        </ui:Button>
                    </StackPanel>

                    <Border BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="4" Padding="6">
                        <ListBox ItemsSource="{Binding DataContext.SelectedFiles, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 Background="Transparent" BorderThickness="0" FontFamily="Consolas" FontSize="11.5"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="2,1" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="#8A8AA0" Margin="0,6,0,2" />
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ListBox.GroupStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <Border DockPanel.Dock="Right" CornerRadius="3" Padding="6,1" Margin="6,0,16,0" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1F7FE0A0" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Changed}" Value="True">
                                                            <Setter Property="Background" Value="#33D0A04A" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontFamily="Segoe UI" FontSize="9.5" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="UNCHANGED" />
                                                        <Setter Property="Foreground" Value="#7FE0A0" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Changed}" Value="True">
                                                                <Setter Property="Text" Value="CHANGED" />
                                                                <Setter Property="Foreground" Value="#E8C06A" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <TextBlock Text="{Binding Path}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </DockPanel>
            </ui:Card>
        </Grid>
    </DockPanel>
</UserControl>
