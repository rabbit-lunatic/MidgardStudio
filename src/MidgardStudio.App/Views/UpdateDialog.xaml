<Window x:Class="MidgardStudio.App.Views.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" Topmost="False"
        WindowStartupLocation="CenterOwner" Width="460" Height="380">

    <!-- Branded card matching the splash: radial-gradient fill, violet glow + drop shadow, spring entrance. -->
    <Border x:Name="Card" Margin="22" CornerRadius="18" BorderThickness="1" BorderBrush="#3FA15CF5"
            Opacity="0" RenderTransformOrigin="0.5,0.5" ClipToBounds="True"
            MouseLeftButtonDown="OnDrag">
        <Border.Background>
            <RadialGradientBrush GradientOrigin="0.5,0.16" Center="0.5,0.22" RadiusX="1.0" RadiusY="1.15">
                <GradientStop Color="#26193F" Offset="0.0" />
                <GradientStop Color="#140F24" Offset="0.55" />
                <GradientStop Color="#0A0712" Offset="1.0" />
            </RadialGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#8D2DF2" BlurRadius="44" ShadowDepth="0" Opacity="0.42" />
        </Border.Effect>
        <Border.RenderTransform>
            <ScaleTransform x:Name="CardScale" ScaleX="0.94" ScaleY="0.94" />
        </Border.RenderTransform>

        <Grid Margin="26,16,26,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/logo.png" Width="24" Height="24" Margin="0,0,9,0"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="Midgard Studio" FontSize="13.5" FontWeight="SemiBold" Foreground="#E8E2F4" VerticalAlignment="Center" />
                    <Border Background="#2A2140" CornerRadius="6" Padding="7,1" Margin="9,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="CurrentVersionText" Foreground="#BBA9E6" FontSize="11" />
                    </Border>
                </StackPanel>
                <ui:Button x:Name="CloseX" HorizontalAlignment="Right" VerticalAlignment="Top" Appearance="Transparent" Padding="6"
                           ToolTip="Close">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Dismiss24" FontSize="15" /></ui:Button.Icon>
                </ui:Button>
            </Grid>

            <!-- Body -->
            <Grid Grid.Row="1">
                <Ellipse x:Name="Glow" Width="250" Height="250" VerticalAlignment="Center" HorizontalAlignment="Center"
                         Margin="0,-6,0,0" Opacity="0.42" RenderTransformOrigin="0.5,0.5" IsHitTestVisible="False">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop x:Name="GlowStop" Color="#5C9A3DF5" Offset="0.0" />
                            <GradientStop Color="#00120A20" Offset="0.7" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="GlowScale" ScaleX="0.9" ScaleY="0.9" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Checking -->
                <StackPanel x:Name="CheckingPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image Source="/Assets/logo.png" Width="72" Height="72" HorizontalAlignment="Center"
                           RenderTransformOrigin="0.5,0.5" RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.RenderTransform><TranslateTransform x:Name="LogoFloat" Y="0" /></Image.RenderTransform>
                    </Image>
                    <TextBlock Text="Checking for updates…" FontSize="14" Foreground="#D8D2EC" HorizontalAlignment="Center" Margin="0,22,0,0" />
                    <Border Width="240" Height="4" CornerRadius="2" Background="#1AFFFFFF" Margin="0,16,0,0" ClipToBounds="True">
                        <Border x:Name="Shimmer" Width="90" Height="4" CornerRadius="2" HorizontalAlignment="Left">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#008D2DF2" Offset="0.0" />
                                    <GradientStop Color="#D916FB" Offset="0.5" />
                                    <GradientStop Color="#008D2DF2" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.RenderTransform><TranslateTransform x:Name="ShimmerMove" X="-90" /></Border.RenderTransform>
                        </Border>
                    </Border>
                </StackPanel>

                <!-- Result -->
                <StackPanel x:Name="ResultPanel" Visibility="Collapsed" Opacity="0"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border x:Name="StatusIconBg" Width="78" Height="78" CornerRadius="39" HorizontalAlignment="Center"
                            Background="#2249C97A" RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform><ScaleTransform x:Name="StatusIconScale" ScaleX="0.6" ScaleY="0.6" /></Border.RenderTransform>
                        <ui:SymbolIcon x:Name="StatusIcon" Symbol="CheckmarkCircle48" FontSize="42" Foreground="#5AE0A0" />
                    </Border>
                    <TextBlock x:Name="ResultTitle" FontSize="21" FontWeight="SemiBold" Foreground="#F1ECFB"
                               HorizontalAlignment="Center" Margin="0,16,0,0" />
                    <TextBlock x:Name="ResultSubtitle" FontSize="12.5" Foreground="#A79FC2" HorizontalAlignment="Center"
                               TextAlignment="Center" TextWrapping="Wrap" MaxWidth="330" Margin="0,7,0,0" LineHeight="18" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,22,0,0">
                        <ui:Button x:Name="PrimaryBtn" Appearance="Primary" MinWidth="132" Margin="0,0,8,0" Visibility="Collapsed" />
                        <ui:Button x:Name="SecondaryBtn" Appearance="Secondary" MinWidth="100" Content="Close" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>

        <Border.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="Card" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.28" />
                        <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.45">
                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5" /></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.45">
                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5" /></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity" From="0.3" To="0.6" Duration="0:0:1.7" AutoReverse="True" RepeatBehavior="Forever" />
                        <DoubleAnimation Storyboard.TargetName="GlowScale" Storyboard.TargetProperty="ScaleX" From="0.9" To="1.08" Duration="0:0:1.7" AutoReverse="True" RepeatBehavior="Forever" />
                        <DoubleAnimation Storyboard.TargetName="GlowScale" Storyboard.TargetProperty="ScaleY" From="0.9" To="1.08" Duration="0:0:1.7" AutoReverse="True" RepeatBehavior="Forever" />
                        <DoubleAnimation Storyboard.TargetName="LogoFloat" Storyboard.TargetProperty="Y" From="0" To="-5" Duration="0:0:1.9" AutoReverse="True" RepeatBehavior="Forever" />
                        <DoubleAnimation Storyboard.TargetName="ShimmerMove" Storyboard.TargetProperty="X" From="-90" To="240" Duration="0:0:1.2" RepeatBehavior="Forever" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
    </Border>
</Window>
